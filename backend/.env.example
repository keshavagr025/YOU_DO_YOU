# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Fallback to local MongoDB if not set
MONGODB_URI=mongodb://localhost:27017/resume_analytics

# Authentication
JWT_SECRET=your_jwt_secret_here

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# AI & API Providers
# 1. OpenRouter (ChatBot)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. OpenAI (AI processor)
OPENAI_API_KEY=your_openai_api_key_here

# 3. Cohere (Resume Analyzer & Mock Interview)
COHERE_API_KEY=your_cohere_api_key_here

# 4. Google Gemini (Mock Interview)
GEMINI_API_KEY=your_gemini_api_key_here

# 5. Groq (Mock Interview)
GROQ_API_KEY=your_groq_api_key_here

# 6. AssemblyAI (Mock Interview Transcription)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# 7. RapidAPI (Jobs & Salaries)
RAPIDAPI_KEY=your_rapidapi_key_here

# 8. Learning APIs (YouTube & Udemy)
YOUTUBE_API_KEY=your_youtube_api_key_here
UDEMY_CLIENT_ID=your_udemy_client_id_here
UDEMY_CLIENT_SECRET=your_udemy_client_secret_here
